{
  "private": true,
  "name": "mailpit-monorepo",
  "description": "Monorepo for mailpit-api and mailpit-ws packages",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mpspahr/mailpit-api.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "vitest run",
    "test:unit": "vitest run --project mailpit-api --project mailpit-ws",
    "test:e2e": "vitest run --project e2e",
    "coverage": "vitest run --coverage",
    "pretty": "npx prettier . --write",
    "lint": "npx eslint --fix packages/*/src packages/*/tests tests",
    "docs": "typedoc"
  },
  "author": "Matthew Spahr",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/eslint-plugin": "^1.6.14",
    "dotenv": "^17.3.1",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "tsdown": "^0.21.8",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.19",
    "typedoc-github-theme": "^0.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.2"
  }
}
